{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "electron-preload",
    "baseUrl": "."
  },
  "include": ["electron-preload"],
  "exclude": ["node_modules", "dist", "src", "electron"]
}
